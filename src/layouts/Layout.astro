---
import '../styles/global.css';
import '../styles/variables.css';
import FixedFooter from '../components/ui/FixedFooter.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Early viewport scaling: applied before first paint via CSS variable to avoid flicker.
         Recomputes only on width change so mobile URL-bar show/hide doesn't jolt the layout. -->
    <script is:inline>
      (function () {
        var DESIGN_WIDTH = 440;
        var DESIGN_HEIGHT = 959;
        var lastWidth = -1;
        function applyScale(force) {
          var vw = document.documentElement.clientWidth || window.innerWidth;
          if (!force && vw === lastWidth) return; // height-only change (URL bar) → keep scale stable
          lastWidth = vw;
          var vh = window.innerHeight;
          var scaleX = Math.min(vw, DESIGN_WIDTH) / DESIGN_WIDTH;
          var scaleY = vh / DESIGN_HEIGHT;
          var scale = Math.min(scaleX, scaleY);
          var root = document.documentElement.style;
          root.setProperty('--screen-scale', String(scale));
          root.setProperty('--screen-w', DESIGN_WIDTH * scale + 'px');
          root.setProperty('--screen-h', DESIGN_HEIGHT * scale + 'px');
        }
        applyScale(true);
        window.addEventListener('resize', function () { applyScale(false); });
        window.addEventListener('orientationchange', function () { applyScale(true); });
        document.addEventListener('DOMContentLoaded', function () { applyScale(true); });
      })();
    </script>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@400;500;700;900&display=swap" rel="stylesheet" />
    <link rel="preload" as="image" type="image/webp" href="/img/fv-hero.webp" />
    <title>{title}</title>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-MRXPL4B');</script>
    <!-- End Google Tag Manager -->
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MRXPL4B"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <div class="lp-wrapper">
      <main class="lp-container">
        <slot />
      </main>
      <FixedFooter />
    </div>
  </body>
</html>

<style>
  .lp-wrapper {
    max-width: 440px;
    margin: 0 auto;
    position: relative;
    background-color: var(--background-02);
  }

  .lp-container {
    scroll-snap-type: y mandatory;
    overflow-y: scroll;
    height: 100vh;
    height: 100dvh;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .lp-container::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  /* CTA smooth-scroll */
  document.addEventListener('click', (e) => {
    const link = (e.target as HTMLElement).closest('a[href="#cta"]');
    if (!link) return;
    e.preventDefault();
    const target = document.getElementById('cta');
    if (target) {
      target.scrollIntoView({ behavior: 'smooth' });
    }
  });
</script>
